<index.html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Les Stablecoins — La monnaie numérique qui défie les banques centrales</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #1A2B4A;
  --navy-mid: #243860;
  --gold: #E8A020;
  --gold-light: #F5C55A;
  --gold-pale: #FFF3CD;
  --white: #FFFFFF;
  --off-white: #F4F6FA;
  --light-grey: #E8ECF2;
  --grey: #8C9BB5;
  --dark-grey: #3D4F6E;
  --green: #1D8A4F;
  --green-light: #E8F5EE;
  --red: #C0392B;
  --red-light: #FDECEA;
  --teal: #0D7377;
  --teal-light: #E0F2F3;
  --orange: #D4680A;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--navy);
  color: var(--white);
  overflow-x: hidden;
}

/* ── HERO ─────────────────────────────────── */
.hero {
  min-height: 100vh;
  position: relative;
  display: flex;
  align-items: center;
  padding: 0 6vw;
  overflow: hidden;
}

.hero-bg {
  position: absolute; inset: 0;
  background: 
    radial-gradient(ellipse 80% 60% at 70% 50%, rgba(14, 115, 119, 0.12) 0%, transparent 70%),
    radial-gradient(ellipse 50% 40% at 20% 80%, rgba(232, 160, 32, 0.08) 0%, transparent 60%),
    var(--navy);
}

.hero-grid {
  position: absolute; inset: 0;
  background-image: 
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
}

.hero-gold-bar {
  position: absolute; left: 0; top: 0; bottom: 0; width: 5px;
  background: linear-gradient(to bottom, var(--gold), var(--gold-light), var(--gold));
}

.hero-content { position: relative; z-index: 2; max-width: 900px; }

.hero-eyebrow {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.8s 0.2s forwards;
}

.hero-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(3rem, 8vw, 7rem);
  font-weight: 800;
  line-height: 0.95;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: fadeUp 0.8s 0.4s forwards;
}

.hero-title span { color: var(--gold); }

.hero-subtitle {
  font-size: clamp(1rem, 2vw, 1.25rem);
  font-weight: 300;
  color: var(--grey);
  max-width: 600px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: fadeUp 0.8s 0.6s forwards;
}

.hero-tags {
  display: flex; flex-wrap: wrap; gap: 0.75rem;
  opacity: 0;
  animation: fadeUp 0.8s 0.8s forwards;
}

.tag {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  padding: 0.4rem 1rem;
  border-radius: 2px;
  font-size: 0.8rem;
  font-family: 'DM Mono', monospace;
  color: var(--grey);
  letter-spacing: 0.05em;
}

.hero-sources {
  position: absolute;
  bottom: 2rem; left: 6vw; right: 6vw;
  display: flex; gap: 1rem; flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.8s 1s forwards;
}

.src-badge {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(232, 160, 32, 0.25);
  padding: 0.4rem 0.9rem;
  font-size: 0.7rem;
  font-family: 'DM Mono', monospace;
  color: var(--gold-light);
  border-radius: 2px;
  white-space: nowrap;
}

.scroll-hint {
  position: absolute;
  bottom: 2rem; right: 6vw;
  display: flex; align-items: center; gap: 0.5rem;
  font-size: 0.75rem; color: var(--grey);
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.1em;
  opacity: 0;
  animation: fadeUp 0.8s 1.2s forwards;
}

.scroll-line {
  width: 40px; height: 1px;
  background: linear-gradient(to right, transparent, var(--grey));
}

/* ── SECTIONS ──────────────────────────────── */
section {
  padding: 8rem 6vw;
  position: relative;
}

section.light {
  background: var(--off-white);
  color: var(--navy);
}

.section-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
}

section.light .section-label { color: var(--teal); }

.section-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 800;
  line-height: 1.05;
  margin-bottom: 1rem;
}

.section-sub {
  font-size: 1rem;
  color: var(--grey);
  margin-bottom: 3.5rem;
  font-weight: 300;
  font-style: italic;
  max-width: 700px;
}

section.light .section-sub { color: var(--dark-grey); }

/* ── DEFINITION SECTION ────────────────────── */
.compare-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5px;
  margin-bottom: 3rem;
  border: 1.5px solid rgba(255,255,255,0.08);
}

.compare-card {
  padding: 2.5rem 2rem;
  position: relative;
  overflow: hidden;
  transition: transform 0.3s ease;
}

.compare-card:hover { transform: translateY(-4px); }

.compare-card.bitcoin { background: rgba(192,57,43,0.12); border-top: 3px solid var(--red); }
.compare-card.stablecoin { background: rgba(29,138,79,0.12); border-top: 3px solid var(--green); }
.compare-card.fiat { background: rgba(36,56,96,0.4); border-top: 3px solid var(--gold); }

.compare-card-title {
  font-family: 'Syne', sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  margin-bottom: 0.4rem;
}

.compare-card-sub { font-size: 0.85rem; color: var(--grey); margin-bottom: 1.5rem; }

.compare-big-val {
  font-family: 'Syne', sans-serif;
  font-size: 2.8rem;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 0.3rem;
}

.bitcoin .compare-big-val { color: var(--red); }
.stablecoin .compare-big-val { color: var(--green); }
.fiat .compare-big-val { color: var(--gold); }

.history-note {
  border-left: 3px solid var(--gold);
  padding: 1.5rem 2rem;
  background: rgba(232,160,32,0.06);
  border-radius: 0 4px 4px 0;
}

.history-note strong {
  font-family: 'Syne', sans-serif;
  color: var(--gold);
  font-size: 0.85rem;
  letter-spacing: 0.05em;
  display: block;
  margin-bottom: 0.5rem;
}

/* ── HOW IT WORKS ──────────────────────────── */
.steps-flow {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  margin-bottom: 4rem;
  position: relative;
}

.steps-flow::before {
  content: '';
  position: absolute;
  top: 2.5rem; left: 12.5%; right: 12.5%;
  height: 2px;
  background: linear-gradient(to right, var(--navy-mid), var(--gold), var(--navy-mid));
  z-index: 0;
}

.step {
  text-align: center;
  padding: 0 1.5rem;
  position: relative;
  z-index: 1;
}

.step-num {
  width: 5rem; height: 5rem;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif;
  font-size: 1.8rem;
  font-weight: 800;
  margin: 0 auto 1.5rem;
  border: 2px solid var(--gold);
  background: var(--navy);
  color: var(--gold);
  transition: all 0.3s ease;
}

.step:hover .step-num {
  background: var(--gold);
  color: var(--navy);
  transform: scale(1.1);
}

.step-label {
  font-size: 0.9rem;
  font-weight: 500;
  line-height: 1.5;
  color: var(--light-grey);
}

.types-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.type-card {
  border-radius: 4px;
  overflow: hidden;
  box-shadow: 0 8px 40px rgba(0,0,0,0.25);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.type-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.35);
}

.type-header {
  padding: 1rem 1.5rem;
  font-family: 'Syne', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
}

.type-body {
  padding: 1.5rem;
  background: rgba(255,255,255,0.04);
  font-size: 0.88rem;
  line-height: 1.7;
  color: var(--grey);
}

.type-fiat .type-header { background: var(--green); }
.type-crypto .type-header { background: var(--teal); }
.type-algo .type-header { background: var(--red); }

/* ── STATS BAR ─────────────────────────────── */
.stats-bar {
  background: var(--navy-mid);
  padding: 3rem 6vw;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  border-top: 1px solid rgba(255,255,255,0.05);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.stat-item { text-align: center; }

.stat-value {
  font-family: 'Syne', sans-serif;
  font-size: 2.5rem;
  font-weight: 800;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 0.4rem;
}

.stat-label {
  font-size: 0.8rem;
  color: var(--grey);
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.05em;
}

/* ── SOVEREIGNTY ───────────────────────────── */
.sovereignty-layout {
  display: grid;
  grid-template-columns: 1fr 1.8fr;
  gap: 3rem;
  align-items: start;
}

.big-stat-box {
  background: var(--navy);
  border-radius: 4px;
  padding: 3rem 2rem;
  text-align: center;
  border: 1px solid rgba(255,255,255,0.08);
  position: relative;
  overflow: hidden;
}

.big-stat-box::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 4px;
  background: var(--red);
}

.big-stat-label {
  font-size: 0.8rem;
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--grey);
  margin-bottom: 1.5rem;
}

.big-stat-number {
  font-family: 'Syne', sans-serif;
  font-size: 7rem;
  font-weight: 800;
  color: var(--red);
  line-height: 1;
  margin-bottom: 0.5rem;
}

.big-stat-desc { font-size: 0.9rem; color: var(--grey); line-height: 1.6; margin-bottom: 1rem; }
.big-stat-source { font-size: 0.7rem; color: var(--dark-grey); font-style: italic; }

.risks-list { display: flex; flex-direction: column; gap: 1rem; }

.risk-item {
  display: flex; gap: 1rem; align-items: flex-start;
  padding: 1.2rem 1.5rem;
  background: var(--navy);
  border-left: 3px solid var(--red);
  border-radius: 0 4px 4px 0;
  transition: transform 0.2s ease, border-color 0.2s ease;
}

.risk-item:hover { transform: translateX(4px); border-color: var(--gold); }

.risk-num {
  font-family: 'Syne', sans-serif;
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--red);
  min-width: 2rem;
  line-height: 1;
}

.risk-text { font-size: 0.9rem; color: var(--light-grey); line-height: 1.5; }

.solution-note {
  margin-top: 2.5rem;
  padding: 1.5rem 2rem;
  background: var(--gold-pale);
  color: var(--navy);
  border-radius: 4px;
  border-left: 4px solid var(--gold);
  font-size: 0.9rem;
  line-height: 1.7;
}

/* ── PLAYERS ───────────────────────────────── */
.players-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
}

.players-column-title {
  font-family: 'Syne', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  padding: 0.75rem 1.5rem;
  margin-bottom: 1.5rem;
  border-radius: 3px;
}

.us-col .players-column-title { background: #1A3A6B; }
.eu-col .players-column-title { background: var(--teal); }

.player-card {
  padding: 1.5rem;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 4px;
  margin-bottom: 1rem;
  transition: background 0.2s ease, transform 0.2s ease;
}

.player-card:hover {
  background: rgba(255,255,255,0.08);
  transform: translateY(-2px);
}

.player-header {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 0.6rem;
}

.player-name {
  font-family: 'Syne', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
}

.us-col .player-name { color: #8BB3F0; }
.eu-col .player-name { color: #7DD3D5; }

.player-share {
  font-family: 'DM Mono', monospace;
  font-size: 0.78rem;
  color: var(--gold);
  font-weight: 500;
}

.player-desc { font-size: 0.85rem; color: var(--grey); line-height: 1.6; }

/* ── REGULATION TABLE ──────────────────────── */
.reg-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
  margin-bottom: 2rem;
}

.reg-table thead tr {
  background: var(--navy-mid);
}

.reg-table th {
  padding: 1rem 1.5rem;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.9rem;
  text-align: left;
}

.reg-table th:first-child { color: var(--grey); }
.reg-table th:nth-child(2) { color: var(--gold-light); }
.reg-table th:nth-child(3) { color: #7DD3D5; }

.reg-table tbody tr:nth-child(odd) { background: rgba(255,255,255,0.03); }
.reg-table tbody tr:nth-child(even) { background: rgba(255,255,255,0.015); }

.reg-table tbody tr { transition: background 0.2s ease; }
.reg-table tbody tr:hover { background: rgba(232,160,32,0.06); }

.reg-table td {
  padding: 0.85rem 1.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  color: var(--light-grey);
  vertical-align: middle;
}

.reg-table td:first-child { color: var(--grey); font-weight: 500; font-size: 0.85rem; }

.convergence-badge {
  display: inline-block;
  background: rgba(232,160,32,0.15);
  border: 1px solid rgba(232,160,32,0.4);
  color: var(--gold);
  padding: 0.6rem 1.5rem;
  border-radius: 2px;
  font-size: 0.82rem;
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.03em;
  line-height: 1.6;
}

/* ── RISKS CHANNELS ────────────────────────── */
.channels-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.channel-card {
  border-radius: 4px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  transition: transform 0.3s ease;
}

.channel-card:hover { transform: translateY(-6px); }

.channel-header {
  padding: 1.2rem 1.5rem;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--white);
}

.channel-body {
  padding: 1.5rem;
  background: rgba(26,43,74,0.8);
  font-size: 0.88rem;
  line-height: 1.8;
  color: var(--grey);
  min-height: 200px;
}

.channel-card.red .channel-header { background: var(--red); }
.channel-card.teal .channel-header { background: var(--teal); }
.channel-card.gold .channel-header { background: var(--gold); color: var(--navy); }

.empirical-box {
  background: var(--navy-mid);
  border-left: 4px solid var(--gold);
  padding: 2rem 2.5rem;
  border-radius: 0 4px 4px 0;
}

.empirical-title {
  font-family: 'Syne', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: 0.75rem;
}

.empirical-text { font-size: 0.9rem; color: var(--light-grey); line-height: 1.7; }

/* ── EMBEDDED SUPERVISION ──────────────────── */
.principles-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}

.principle-card {
  display: flex; gap: 1.5rem; align-items: flex-start;
  padding: 2rem;
  border-radius: 4px;
  background: var(--navy);
  border: 1px solid rgba(255,255,255,0.07);
  transition: border-color 0.2s ease, transform 0.2s ease;
}

.principle-card:hover { transform: translateY(-3px); }
.principle-card:nth-child(1) { border-top: 3px solid var(--navy-mid); }
.principle-card:nth-child(1):hover { border-top-color: var(--gold); border-color: var(--gold); }
.principle-card:nth-child(2) { border-top: 3px solid var(--teal); }
.principle-card:nth-child(2):hover { border-color: var(--teal); }
.principle-card:nth-child(3) { border-top: 3px solid var(--green); }
.principle-card:nth-child(3):hover { border-color: var(--green); }
.principle-card:nth-child(4) { border-top: 3px solid var(--orange); }
.principle-card:nth-child(4):hover { border-color: var(--orange); }

.principle-num {
  font-family: 'Syne', sans-serif;
  font-size: 2.5rem;
  font-weight: 800;
  min-width: 2.5rem;
  line-height: 1;
}

.principle-card:nth-child(1) .principle-num { color: var(--gold); }
.principle-card:nth-child(2) .principle-num { color: var(--teal); }
.principle-card:nth-child(3) .principle-num { color: var(--green); }
.principle-card:nth-child(4) .principle-num { color: var(--orange); }

.principle-content h4 {
  font-family: 'Syne', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
  color: var(--white);
}

.principle-content p { font-size: 0.88rem; color: var(--grey); line-height: 1.6; }

/* ── CBDC ──────────────────────────────────── */
.cbdc-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  margin-bottom: 2.5rem;
}

.cbdc-feature-list { display: flex; flex-direction: column; gap: 0.6rem; }

.cbdc-feature {
  display: flex; align-items: center; gap: 0.8rem;
  padding: 0.75rem 1rem;
  border-radius: 3px;
  font-size: 0.9rem;
  transition: background 0.2s ease;
}

.cbdc-feature:hover { background: rgba(13,115,119,0.1); }

.cbdc-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--teal);
  flex-shrink: 0;
}

.cbdc-compare-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.88rem;
}

.cbdc-compare-table th {
  padding: 0.75rem 1rem;
  font-family: 'Syne', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  text-align: center;
  background: rgba(255,255,255,0.05);
  border-bottom: 2px solid rgba(255,255,255,0.1);
}

.cbdc-compare-table th:first-child { text-align: left; color: var(--grey); }
.cbdc-compare-table th:nth-child(2) { color: var(--green); }
.cbdc-compare-table th:nth-child(3) { color: var(--red); }

.cbdc-compare-table td {
  padding: 0.75rem 1rem;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  text-align: center;
  color: var(--grey);
}

.cbdc-compare-table td:first-child {
  text-align: left;
  font-weight: 500;
  color: var(--light-grey);
  font-size: 0.85rem;
}

.cbdc-compare-table td.ok { color: var(--green); font-weight: 600; }
.cbdc-compare-table td.nok { color: var(--red); font-weight: 600; }

.usa-warning {
  background: rgba(232,160,32,0.08);
  border: 1px solid rgba(232,160,32,0.3);
  border-radius: 4px;
  padding: 1.5rem 2rem;
  font-size: 0.9rem;
  line-height: 1.7;
  color: var(--light-grey);
}

.usa-warning strong { color: var(--gold); }

/* ── COMMERCIAL BANKS + REVOLUT ────────────── */
.banks-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-bottom: 3rem;
}

.banks-box {
  border-radius: 4px;
  overflow: hidden;
}

.banks-box-header {
  padding: 1rem 1.5rem;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 0.95rem;
}

.banks-box.threat .banks-box-header { background: var(--red); }
.banks-box.response .banks-box-header { background: var(--green); }

.banks-box-body {
  padding: 1.5rem;
  background: rgba(255,255,255,0.03);
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.banks-item {
  display: flex; gap: 0.6rem; align-items: flex-start;
  font-size: 0.88rem; color: var(--grey); line-height: 1.5;
}

.banks-item::before {
